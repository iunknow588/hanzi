{
  "name": "hanzi-writer-renderers",
  "version": "0.1.0",
  "description": "SVG/Canvas renderer implementations for Hanzi Writer, extracted for reuse",
  "main": "src/renderers/index.ts",
  "module": "src/renderers/index.ts",
  "types": "src/renderers/index.ts",
  "license": "MIT",
  "private": false,
  "sideEffects": false,
  "files": [
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json"
  },
  "exports": {
    ".": {
      "types": "./src/renderers/index.ts",
      "import": "./src/renderers/index.ts",
      "require": "./src/renderers/index.ts"
    },
    "./svg": {
      "types": "./src/renderers/svg/index.ts",
      "import": "./src/renderers/svg/index.ts",
      "require": "./src/renderers/svg/index.ts"
    },
    "./canvas": {
      "types": "./src/renderers/canvas/index.ts",
      "import": "./src/renderers/canvas/index.ts",
      "require": "./src/renderers/canvas/index.ts"
    },
    "./HanziWriterRendererBase": {
      "types": "./src/renderers/HanziWriterRendererBase.ts",
      "import": "./src/renderers/HanziWriterRendererBase.ts",
      "require": "./src/renderers/HanziWriterRendererBase.ts"
    },
    "./RenderTargetBase": {
      "types": "./src/renderers/RenderTargetBase.ts",
      "import": "./src/renderers/RenderTargetBase.ts",
      "require": "./src/renderers/RenderTargetBase.ts"
    },
    "./StrokeRendererBase": {
      "types": "./src/renderers/StrokeRendererBase.ts",
      "import": "./src/renderers/StrokeRendererBase.ts",
      "require": "./src/renderers/StrokeRendererBase.ts"
    }
  },
  "typesVersions": {
    "*": {
      "svg": [
        "src/renderers/svg/index.ts"
      ],
      "canvas": [
        "src/renderers/canvas/index.ts"
      ],
      "HanziWriterRendererBase": [
        "src/renderers/HanziWriterRendererBase.ts"
      ],
      "RenderTargetBase": [
        "src/renderers/RenderTargetBase.ts"
      ],
      "StrokeRendererBase": [
        "src/renderers/StrokeRendererBase.ts"
      ]
    }
  }
}
