{
  "name": "hanzi-writer-renderers",
  "version": "0.1.0",
  "description": "SVG/Canvas renderer implementations for Hanzi Writer, extracted for reuse",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "license": "MIT",
  "private": false,
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    },
    "./svg": {
      "types": "./dist/svg/index.d.ts",
      "import": "./dist/svg/index.js",
      "require": "./dist/svg/index.js"
    },
    "./canvas": {
      "types": "./dist/canvas/index.d.ts",
      "import": "./dist/canvas/index.js",
      "require": "./dist/canvas/index.js"
    },
    "./HanziWriterRendererBase": {
      "types": "./dist/HanziWriterRendererBase.d.ts",
      "import": "./dist/HanziWriterRendererBase.js",
      "require": "./dist/HanziWriterRendererBase.js"
    },
    "./RenderTargetBase": {
      "types": "./dist/RenderTargetBase.d.ts",
      "import": "./dist/RenderTargetBase.js",
      "require": "./dist/RenderTargetBase.js"
    },
    "./StrokeRendererBase": {
      "types": "./dist/StrokeRendererBase.d.ts",
      "import": "./dist/StrokeRendererBase.js",
      "require": "./dist/StrokeRendererBase.js"
    }
  },
  "typesVersions": {
    "*": {
      "svg": [
        "dist/svg/index.d.ts"
      ],
      "canvas": [
        "dist/canvas/index.d.ts"
      ],
      "HanziWriterRendererBase": [
        "dist/HanziWriterRendererBase.d.ts"
      ],
      "RenderTargetBase": [
        "dist/RenderTargetBase.d.ts"
      ],
      "StrokeRendererBase": [
        "dist/StrokeRendererBase.d.ts"
      ]
    }
  }
}
