{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "types": [
      "vite/client"
    ],
    "baseUrl": ".",
    "paths": {
      "hanzi-writer": ["../../packages/hanzi-writer/src/HanziWriter.ts"],
      "hanzi-writer/*": ["../../packages/hanzi-writer/src/*"],
      "hanzi-writer-data-client": ["../../packages/data-client/index.js"],
      "hanzi-writer-data": ["../../packages/hanzi-writer-data/data"],
      "hanzi-writer-data/*": ["../../packages/hanzi-writer-data/data/*"]
    }
  },
  "include": ["src"]
}
